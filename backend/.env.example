# Application
APP_NAME=Doomscroll
APP_VERSION=1.0.0
DEBUG=true

# Database (PostgreSQL) - matches deployment-local docker-compose
DATABASE_URL=postgresql+asyncpg://doomscroll_user:doomscroll_password@localhost:5433/doomscroll

# Server
API_HOST=0.0.0.0
API_PORT=8000

# Background Jobs
REFRESH_INTERVAL_MINUTES=15

# External APIs
REDDIT_USER_AGENT=Doomscroll/1.0

# Admin
MIGRATION_API_KEY=change-me-in-production

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Redis (optional - for caching)
REDIS_URL=redis://localhost:6379/0

# JWT Authentication
JWT_SECRET_KEY=change-me-in-production-use-a-long-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
