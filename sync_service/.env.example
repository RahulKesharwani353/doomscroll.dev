# Sync Service Environment Configuration

# Database (PostgreSQL) - Required
# This is the same database used by the backend API
DATABASE_URL=postgresql+asyncpg://doomscroll_user:doomscroll_password@localhost:5433/doomscroll

# Debug mode (optional)
DEBUG=false

# Reddit API User-Agent (optional)
# Reddit requires specific User-Agent format: platform:app_id:version (by /u/username)
REDDIT_USER_AGENT=windows:doomscroll:1.0 (by /u/doomscroll_bot)
